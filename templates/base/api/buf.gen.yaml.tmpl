version: v2
managed:
  enabled: true
  override:
    - file_option: go_package_prefix
      value: {{.ModuleName}}/internal/gen
plugins:
  # Go protocol buffer code generation
  - remote: buf.build/protocolbuffers/go:v1.34.2
    out: internal/gen
    opt:
      - paths=source_relative

  # gRPC service stubs
  - remote: buf.build/grpc/go:v1.5.1
    out: internal/gen
    opt:
      - paths=source_relative

  # gRPC-Gateway HTTP/JSON proxy
  - remote: buf.build/grpc-ecosystem/gateway:v2.20.0
    out: internal/gen
    opt:
      - paths=source_relative
      - generate_unbound_methods=true

  # OpenAPI v2 documentation
  - remote: buf.build/grpc-ecosystem/openapiv2:v2.20.0
    out: api/openapi
    opt:
      - allow_merge=true
      - merge_file_name=api
